import java.io.*;
import java.util.*;
import java.text.*;
import java.math.*;
import java.util.regex.*;

public class Solution {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int hrs = sc.nextInt();
        int min = sc.nextInt();
        int sec = sc.nextInt();

            hrs = hrs + (min/60);
            min = min%60;
            min = min +(sec/60);
            sec = sec%60 ;

        
        
        System.out.println("Total Number of hours is "+hrs);
        System.out.println("Total Number of minutes is "+min);
        System.out.print("Total Number of seconds is "+sec);
    }
}
