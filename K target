import java.io.*;
import java.util.*;
import java.text.*;
import java.math.*;
import java.util.regex.*;

public class Solution {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int size = sc.nextInt();
        int arr[] = new int[size];
        int target = sc.nextInt();
        int count = -1;
        for(int i=0;i<size;i++){
            arr[i] = sc.nextInt();
            if(arr[i]==target){
                count++;
            }
        }
        System.out.println(count);
    }
}
