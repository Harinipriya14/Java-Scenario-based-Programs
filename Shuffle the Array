class Solution {
    public int[] shuffle(int[] nums, int n) {
        int k=1;
        int arr[] = new int[nums.length];
        for(int i = 0;i<nums.length;i++){
            if(i==0 || i==nums.length-1){
                arr[i]=nums[i];
            }
            else if(i%2!=0){
                arr[i]=nums[n];
                n++;
            }
            else if(i%2==0){
                arr[i]=nums[k];
                k++;
            }
        }
        return arr;
    }
}
