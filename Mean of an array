import java.io.*;
import java.util.*;
import java.text.*;
import java.math.*;
import java.util.regex.*;

public class Solution {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();
        int arr[] = new int[n];
        float sum = 0;
        for(int i = 0;i<n;i++){
            arr[i]=sc.nextInt();
            sum = sum + arr[i];
        }
        System.out.printf("Mean:%.2f",(sum/n));
    }
}
